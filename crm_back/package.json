{
  "name": "crm-jptv-back",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start:boot": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "npm run build && npm run start",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:refresh": "npm run db:push && npm run db:generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:backup": "powershell -ExecutionPolicy Bypass -File scripts/backup-db.ps1",
    "db:backup:install": "powershell -ExecutionPolicy Bypass -File scripts/schedule-backup-task.ps1",
    "db:backup:remove": "powershell -ExecutionPolicy Bypass -File scripts/remove-backup-task.ps1",
    "firewall:api": "powershell -ExecutionPolicy Bypass -File scripts/firewall-api.ps1",
    "api:status": "powershell -ExecutionPolicy Bypass -File scripts/api-health.ps1",
    "api:ensure": "powershell -ExecutionPolicy Bypass -File scripts/ensure-api.ps1",
    "api:restart": "powershell -ExecutionPolicy Bypass -File scripts/api-restart.ps1",
    "api:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-api-stability.ps1",
    "api:startup:install": "powershell -ExecutionPolicy Bypass -File scripts/schedule-api-startup-task.ps1",
    "api:startup:remove": "powershell -ExecutionPolicy Bypass -File scripts/remove-api-startup-task.ps1",
    "api:watchdog:install": "powershell -ExecutionPolicy Bypass -File scripts/schedule-api-watchdog-task.ps1",
    "api:watchdog:remove": "powershell -ExecutionPolicy Bypass -File scripts/remove-api-watchdog-task.ps1",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.5",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3"
  }
}
