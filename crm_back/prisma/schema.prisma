generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Dispositivo {
  id        Int      @id @default(autoincrement())
  nome      String
  modelo    String?
  descricao String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Cliente {
  id           Int      @id @default(autoincrement())
  nome         String
  telefone     String
  planoId      Int?
  plano        Plano?   @relation(fields: [planoId], references: [id])
  servidor     String?
  usuario      String?
  senha        String?
  aplicativoId Int?
  aplicativo   Aplicativo? @relation(fields: [aplicativoId], references: [id])
  aparelho     String?
  modelo       String?
  macAddress   String?
  qtdTelas     Int      @default(1)
  dispositivos String?
  ativadoEm    DateTime?
  expiraEm     DateTime?
  vencimento   Int
  valorMensal  Float    @default(0)
  incluirCobrancas Boolean @default(true)
  cortesia         Boolean @default(false)
  /// Status derivado de expiraEm na API — não atualizar manualmente no banco
  status       String   @default("ATIVO")
  observacao   String?
  createdAt    DateTime @default(now())
  mensalidades Mensalidade[]
}

model Mensalidade {
  id         Int      @id @default(autoincrement())
  clienteId  Int
  cliente    Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  referencia String
  valor      Float
  vencimento DateTime
  status     String   @default("PENDENTE")
  pagoEm     DateTime?
  ultimoContatoEm DateTime?
  createdAt  DateTime @default(now())
  enviosAutomaticos EnvioAutomatico[]
}

model AutomacaoConfig {
  id                     Int       @id @default(autoincrement())
  lembretesAtivos        Boolean   @default(false)
  cobrancaAtrasadosAtiva Boolean   @default(false)
  horariosEnvio          String    @default("09:00,18:00")
  intervaloAtrasadosDias Int       @default(3)
  templateLembreteNome   String    @default("crm_lembrete")
  templateCobrancaNome   String    @default("crm_cobranca")
  templateLinguagem      String    @default("pt_BR")
  ultimaExecucaoEm       DateTime?
  ultimoHorarioExecutado String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model EnvioAutomatico {
  id              Int          @id @default(autoincrement())
  mensalidadeId   Int?
  mensalidade     Mensalidade? @relation(fields: [mensalidadeId], references: [id], onDelete: SetNull)
  clienteId       Int
  tipo            String
  telefone        String
  status          String
  mensagemPreview String?
  metaMessageId   String?
  erro            String?
  enviadoEm       DateTime     @default(now())

  @@index([mensalidadeId, tipo, enviadoEm])
  @@index([clienteId])
}

model Aplicativo {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String?
  logo      String?
  android   String?
  androidTv String?
  ios       String?
  windows   String?
  mac       String?
  tutorial  String?
  mensagem  String?
  requerMac       Boolean  @default(false)
  requerDeviceKey Boolean  @default(false)
  requerCodigo    Boolean  @default(false)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  clientes  Cliente[]
}

model Plano {
  id           Int      @id @default(autoincrement())
  nome         String
  valor        Float
  diasValidade Int
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())
  clientes     Cliente[]
}

model Configuracao {
  id                 Int      @id @default(autoincrement())
  nomeEmpresa        String   @default("JPTV")
  whatsapp           String?
  email              String?
  site               String?
  instagram          String?
  chavePix           String?
  tipoPix            String?
  favorecidoPix      String?
  corPrincipal       String   @default("#7C3AED")
  diasAntecedenciaLembrete Int @default(5)
  mensagemBoasVindas String?
  mensagemCobranca   String?
  mensagemLembrete   String?
  mensagemRenovacao  String?
  mensagemBloqueio   String?
  mensagemRecibo     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Usuario {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  nome         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
