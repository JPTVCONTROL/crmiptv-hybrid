generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Dispositivo {
  id        Int      @id @default(autoincrement())
  nome      String
  modelo    String?
  descricao String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Cliente {
  id           Int      @id @default(autoincrement())
  nome         String
  telefone     String
  planoId      Int?
  plano        Plano?   @relation(fields: [planoId], references: [id])
  servidor     String?
  usuario      String?
  senha        String?
  aplicativoId Int?
  aplicativo   Aplicativo? @relation(fields: [aplicativoId], references: [id])
  aparelho     String?
  modelo       String?
  macAddress   String?
  qtdTelas     Int      @default(1)
  dispositivos String?
  ativadoEm    DateTime?
  expiraEm     DateTime?
  vencimento   Int
  valorMensal  Float    @default(0)
  /// Custo mensal de crédito/painel por cliente.
  custoCredito Float    @default(0)
  incluirCobrancas Boolean @default(true)
  incluirCampanhas Boolean @default(true)
  cortesia         Boolean @default(false)
  /// Apenas contato — sem plano, vencimento ou cobrança.
  somenteContato   Boolean @default(false)
  /// Ativo operacional (manual). Quando false, sai das cobranças.
  ativo        Boolean  @default(true)
  /// Legado — status exposto na API é calculado em clienteStatus.ts
  status       String   @default("ATIVO")
  observacao   String?
  createdAt    DateTime @default(now())
  mensalidades Mensalidade[]
  campanhaEnvios CampanhaEnvio[]
  tarefas        Tarefa[]

  @@index([expiraEm])
  @@index([planoId])
}

model Campanha {
  id        Int             @id @default(autoincrement())
  titulo    String
  tipo      String          @default("AVISO")
  mensagem  String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  envios    CampanhaEnvio[]
}

model CampanhaEnvio {
  id         Int      @id @default(autoincrement())
  campanhaId Int
  campanha   Campanha @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  clienteId  Int
  cliente    Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  enviadoEm  DateTime @default(now())

  @@unique([campanhaId, clienteId])
  @@index([campanhaId])
  @@index([clienteId])
}

model Mensalidade {
  id         Int      @id @default(autoincrement())
  clienteId  Int
  cliente    Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  referencia String
  valor      Float
  vencimento DateTime
  status     String   @default("PENDENTE")
  pagoEm     DateTime?
  ultimoContatoEm DateTime?
  bloqueioEnviadoEm DateTime?
  createdAt  DateTime @default(now())

  @@index([clienteId])
  @@index([status])
  @@index([vencimento])
  @@index([pagoEm])
}

model Aplicativo {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String?
  logo      String?
  android   String?
  androidTv String?
  ios       String?
  windows   String?
  mac       String?
  tutorial  String?
  mensagem  String?
  requerMac       Boolean  @default(false)
  requerDeviceKey Boolean  @default(false)
  requerCodigo    Boolean  @default(false)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  clientes  Cliente[]
}

model Plano {
  id           Int      @id @default(autoincrement())
  nome         String
  valor        Float
  diasValidade Int
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())
  clientes     Cliente[]
}

model Configuracao {
  id                 Int      @id @default(autoincrement())
  nomeEmpresa        String   @default("JPTV")
  whatsapp           String?
  email              String?
  site               String?
  instagram          String?
  chavePix           String?
  tipoPix            String?
  favorecidoPix      String?
  corPrincipal       String   @default("#7C3AED")
  diasAntecedenciaLembrete Int @default(5)
  metaNovosClientesQtd Int @default(10)
  metaNovosClientesDias Int @default(30)
  metaNovosClientesInicioEm DateTime?
  metaNovosClientesFimEm DateTime?
  mensagemBoasVindas String?
  mensagemCobranca   String?
  mensagemLembrete   String?
  mensagemRenovacao  String?
  mensagemBloqueio   String?
  mensagemRecibo     String?
  /** JSON: Record<PontoDisparoAutomacao, string> — mensagens do funil progressivo. */
  mensagensProgressivas String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Usuario {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  nome         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Tarefa {
  id           Int       @id @default(autoincrement())
  titulo       String
  descricao    String?
  clienteId    Int?
  cliente      Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  vencimentoEm DateTime
  concluida    Boolean   @default(false)
  concluidaEm  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([concluida])
  @@index([vencimentoEm])
  @@index([clienteId])
}

model DespesaMensal {
  id         Int      @id @default(autoincrement())
  nome       String
  valor      Float
  categoria  String   @default("OUTRO")
  ativo      Boolean  @default(true)
  observacao String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PainelCredito {
  id            Int      @id @default(autoincrement())
  codigo        String   @unique
  nome          String
  saldo         Int      @default(0)
  custoUnitario Float    @default(0)
  urlPainel     String?
  loginPainel   String?
  senhaPainel   String?
  ativo         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  movimentos    MovimentoCreditoPainel[]
}

model MovimentoCreditoPainel {
  id            Int           @id @default(autoincrement())
  painelId      Int
  painel        PainelCredito @relation(fields: [painelId], references: [id], onDelete: Cascade)
  tipo          String
  quantidade    Int           @default(1)
  valorUnitario Float
  valorTotal    Float
  clienteId     Int?
  mensalidadeId Int?
  observacao    String?
  createdAt     DateTime      @default(now())

  @@index([painelId])
  @@index([createdAt])
  @@index([clienteId])
}
