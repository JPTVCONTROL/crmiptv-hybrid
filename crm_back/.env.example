DATABASE_URL="file:./dev.db"
PORT=3001
NODE_ENV=development

# Autenticação (admin único — usado no seed inicial)
JWT_SECRET="altere-esta-chave-em-producao"
JWT_EXPIRES_IN="7d"
ADMIN_EMAIL="admin@jptv.com.br"
ADMIN_PASSWORD="admin123"
ADMIN_NOME="Administrador"

# CORS — origens permitidas (separadas por vírgula)
CORS_ORIGINS="http://localhost:4200,http://127.0.0.1:4200,capacitor://localhost,http://localhost"

# WhatsApp Cloud API (Meta) — automações
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN="crm-jptv-webhook"
WHATSAPP_APP_SECRET=""
WHATSAPP_API_VERSION="v21.0"
# Defina false para desligar o agendador interno (use Task Scheduler + POST /automacoes/executar)
AUTOMACAO_SCHEDULER="true"
