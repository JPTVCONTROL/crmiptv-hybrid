{
  "name": "crm-jptv",
  "version": "1.0.0",
  "private": true,
  "description": "CRM JPTV — API + frontend",
  "scripts": {
    "predev": "npx --yes kill-port 4200 3001",
    "dev": "concurrently -k -n back,front -c blue,green \"npm run dev --prefix crm_back\" \"npm run start --prefix crm_front\"",
    "dev:back": "npm run dev --prefix crm_back",
    "dev:front": "npm run start --prefix crm_front",
    "api:status": "npm run api:status --prefix crm_back",
    "api:ensure": "npm run api:ensure --prefix crm_back",
    "api:restart": "npm run api:restart --prefix crm_back",
    "api:setup": "npm run api:setup --prefix crm_back",
    "api:startup:install": "npm run api:startup:install --prefix crm_back",
    "api:startup:remove": "npm run api:startup:remove --prefix crm_back",
    "api:watchdog:install": "npm run api:watchdog:install --prefix crm_back",
    "api:watchdog:remove": "npm run api:watchdog:remove --prefix crm_back",
    "api:firewall": "npm run firewall:api --prefix crm_back",
    "app:publish": "npm run app:publish --prefix crm_front",
    "build": "npm run build --prefix crm_back && npm run build --prefix crm_front",
    "test": "npm run test --prefix crm_back && npm run test:unit --prefix crm_front"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
